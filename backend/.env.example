NODE_ENV=development
DATABASE_URL=postgresql://user:password@localhost:5432/kwik_ride_db?schema=public
PORT=3000
HOST=localhost
CORS_ORIGIN=
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=3600

# Admin User Configuration
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin@123456
ADMIN_NAME=System Administrator
ADMIN_PHONE=+250788000000
ADMIN_CITY=Kigali
ADMIN_COUNTRY=Rwanda

# JWT Authentication Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Mail Configuration
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM="Life Care <your-email@gmail.com>"

# SMS Configuration (Pindo)
PINDO_API_KEY=your_pindo_api_key_here
PINDO_API_URL=https://api.pindo.io/v1/sms

# Client Configuration
CLIENT_URL=http://localhost:3000

# Push Notifications (OneSignal - Optional)
ONESIGNAL_APP_ID=
ONESIGNAL_API_KEY=

STRIPE_PUBLIC_KEY=
STRIPE_PRIVATE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PLATFORM_FEE_PERCENT=10
INTOUCHPAY_PARTNER_PASSWORD=
INTOUCHPAY_USERNAME=
INTOUCHPAY_ACCOUNT=
INTOUCHPAY_DISABLE_DEPOSIT_ENDPOINT=