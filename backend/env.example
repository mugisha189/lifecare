# Server Configuration
PORT=3000
HOST=localhost
NODE_ENV=development

# CORS
CORS_ORIGIN=*

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/lifecare?schema=public

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=3600

# JWT Configuration
JWT_SECRET=change-this-secret-in-production-very-important
JWT_REFRESH_SECRET=change-this-refresh-secret-in-production-very-important
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# Mail Configuration (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-email-password
MAIL_FROM="LifeCare" <your-email@gmail.com>

# SMS Configuration (Pindo)
PINDO_API_KEY=your-pindo-api-key
PINDO_API_URL=https://api.pindo.io/v1/sms

# Client URL
CLIENT_URL=http://localhost:3000

# OneSignal Push Notifications (Optional)
ONESIGNAL_APP_ID=your-onesignal-app-id
ONESIGNAL_API_KEY=your-onesignal-api-key

# Payment Gateway Configuration
# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# Platform Fee (percentage, between 1 and 15)
PLATFORM_FEE_PERCENT=10

# IntouchPay Configuration (Mobile Money)
INTOUCHPAY_BASE_URL=https://api.intouchpay.rw
INTOUCHPAY_USERNAME=your_intouchpay_username
INTOUCHPAY_ACCOUNT=your_intouchpay_account_number
INTOUCHPAY_PARTNER_PASSWORD=your_intouchpay_partner_password
INTOUCHPAY_CALLBACK_URL=https://your-domain.com/api/v1/webhooks/intouchpay

# Admin User Configuration (for seeding)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your-secure-password-here
ADMIN_NAME=Admin User
ADMIN_PHONE=+1234567890
ADMIN_CITY=Your City
ADMIN_COUNTRY=Your Country


