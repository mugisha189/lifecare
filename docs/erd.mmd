    Role {
        uuid id PK
        string name
        string description
    }

    User {
        uuid id PK
        uuid roleId FK
        string name
        string email UK
        string phoneNumber UK
        string passwordHash
        enum gender
        enum verificationStatus
        boolean active
    }

    DoctorProfile {
        uuid id PK
        uuid userId FK
        uuid hospitalId FK
        string licenseNumber UK
        string specialization
        enum doctorStatus
    }

    PatientProfile {
        uuid id PK
        uuid userId FK
        uuid insuranceProviderId FK
        date dateOfBirth
        string insuranceNumber
    }

    PharmacistProfile {
        uuid id PK
        uuid userId FK
        uuid hospitalId FK
        uuid pharmacyId FK
        string licenseNumber UK
        enum pharmacistStatus
    }

    LabStaffProfile {
        uuid id PK
        uuid userId FK
        uuid hospitalId FK
        string licenseNumber
        enum labStaffStatus
    }

    Hospital {
        uuid id PK
        string name
        string address
        string city
        boolean active
    }

    Pharmacy {
        uuid id PK
        string name
        string address
        string city
        boolean active
    }

    InsuranceProvider {
        uuid id PK
        string name UK
        float patientDividendPercent
        float insuranceDividendPercent
    }

    Consultation {
        uuid id PK
        string code UK
        uuid doctorId FK
        uuid patientId FK
        datetime date
        int duration
        enum status
    }

    ConsultationNote {
        uuid id PK
        uuid consultationId FK
        uuid userId FK
        text content
        json attachments
    }

    Prescription {
        uuid id PK
        uuid consultationId FK
        uuid doctorId FK
        uuid patientId FK
        uuid pharmacistId FK
        enum status
        datetime dispensedAt
    }

    PrescriptionMedicine {
        uuid id PK
        uuid prescriptionId FK
        uuid medicineId FK
        string dosage
        string frequency
        string duration
        int quantity
    }

    Medicine {
        uuid id PK
        string name
        text description
        boolean active
    }

    PharmacyMedicine {
        uuid id PK
        uuid pharmacyId FK
        uuid medicineId FK
        date inventoryDate
        int quantity
    }

    LabTestType {
        uuid id PK
        string name
        text description
    }

    LabTestTypeQuestion {
        uuid id PK
        uuid labTestTypeId FK
        string label
        enum type
        json options
    }

    LabTest {
        uuid id PK
        uuid consultationId FK
        uuid patientId FK
        uuid doctorId FK
        uuid labStaffId FK
        uuid labTestTypeId FK
        string testName
        enum status
        json results
    }

    EmergencyRequest {
        uuid id PK
        uuid patientId FK
        uuid hospitalId FK
        json location
        enum status
    }

    Review {
        uuid id PK
        uuid userId FK
        uuid consultationId FK
        uuid doctorProfileId FK
        int rating
        text comment
    }

    RefreshToken {
        uuid id PK
        uuid userId FK
        string token UK
        datetime expiresAt
    }

    Notification {
        uuid id PK
        string title
        text content
        datetime sentAt
    }

    NotificationRecipient {
        uuid id PK
        uuid notificationId FK
        uuid userId FK
        boolean isRead
    }
